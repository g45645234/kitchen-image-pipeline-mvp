APP_ENV=local
DATABASE_URL=postgresql+psycopg://app:app@db:5432/kitchen_assets
DATABASE_ECHO=false
STORAGE_ROOT=./storage
EXPORT_ROOT=./exports
DEV_SYNC_JOBS=false
DEFAULT_TARGET_WIDTH=1920
DEFAULT_TARGET_HEIGHT=1080
DEFAULT_MIN_WIDTH=500
DEFAULT_MIN_HEIGHT=300
DEFAULT_SEARCH_LIMIT_PER_QUERY=20
MAX_SEARCH_LIMIT_PER_QUERY=50
MAX_UPLOAD_MB=20
MAX_DOWNLOAD_MB=20
MAX_IMAGE_PIXELS=25000000
# Comma-separated trusted image hosts. Empty is allowed only in APP_ENV=local.
ALLOWED_IMAGE_DOMAINS=
MAX_RUNNING_JOBS=5
MAX_IMAGE_PROCESSING_JOBS=2
KEEP_ORIGINAL_EXIF=true
STRIP_EXIF_PROCESSED=true
STORAGE_CLEANUP_DRY_RUN_BY_DEFAULT=true
REQUIRE_RIGHTS_FOR_FINAL_APPROVAL=true

RUN_BACKGROUND_WORKER=true
ADMIN_API_TOKEN=
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_JOB_TYPES=
JOB_LOCK_TIMEOUT_MINUTES=30
REVIEWER_PROMPT_VERSION=candidate-review-v1
# mock by default; set to anthropic only when external LLM quota use is explicitly intended.
MISTAKE_EXTRACTION_PROVIDER=mock
REVIEWER_TIMEOUT_SECONDS=120
HOST_REVIEWER_STATUS_PATH=./storage/host_reviewer_bridge_status.json
HOST_REVIEWER_STATUS_TTL_SECONDS=30
CODEX_CLI_COMMAND="python3 -m app.commands.reviewer_cli_adapter --reviewer codex --backend-command 'codex exec --sandbox read-only'"
ANTIGRAVITY_CLI_COMMAND="python3 -m app.commands.reviewer_cli_adapter --reviewer antigravity --backend-command '/root/.local/bin/agy --print' --prompt-as-arg"
CLAUDE_CLI_COMMAND="python3 -m app.commands.reviewer_cli_adapter --reviewer claude_cli --backend-command 'runuser -u claudecode -- claude --print --output-format json --no-session-persistence' --prompt-as-arg"
